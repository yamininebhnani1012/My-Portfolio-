  0% { transform: rotate(0deg); }
  10% { transform: rotate(135deg); }
  25% { transform: rotate(245deg); }
  60% { transform: rotate(700deg); }
  75% { transform: rotate(810deg); }
  100% { transform: rotate(3turn); }
}

@keyframes spinner-spin { 
  0% { transform: rotate(0deg); }
  10% { transform: rotate(135deg); }
  25% { transform: rotate(245deg); }
  60% { transform: rotate(700deg); }
  75% { transform: rotate(810deg); }
  100% { transform: rotate(3turn); }
}

